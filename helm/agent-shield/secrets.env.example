# Copy to secrets.env (gitignored) and fill in. Used to populate the gf-secrets Secret.
# For production prefer a real secret manager (AWS Secrets Manager / GCP Secret Manager
# via External Secrets Operator) instead of a file.

# Full SQLAlchemy URL incl. password; user/db must match the chart's config values.
AUDIT_DATABASE_URL=postgresql+psycopg://gov:CHANGE-ME-STRONG@db:5432/governed
POSTGRES_PASSWORD=CHANGE-ME-STRONG

# C01 per-tenant checkpoint signing root (base64, >=32 bytes): openssl rand -base64 48
AUDIT_SIGNING_MASTER_KEY=

# C05 trusted agent code-hash allowlist (comma-separated sha256 hex).
REGISTRY_TRUSTED_CODE_HASHES=

# Admin-endpoint token: guards the kill switch / reconcile / reload (PEP + PDP).
# Required — those endpoints are disabled if unset. openssl rand -hex 32.
GF_ADMIN_TOKEN=

# Audit-ingest writer token: authenticates the C01 append/reconcile write. C01 runs
# AUDIT_STORE_ENV=production, so its startup guard REQUIRES this — the audit store crash-loops
# without it (fail-safe, never an unauthenticated ledger). Every producer presents it. Distinct
# secret from GF_ADMIN_TOKEN (separate blast radius). openssl rand -hex 32.
GF_AUDIT_WRITER_TOKEN=

# Auditor-RBAC token for C06's tenant-posture READ surfaces (coverage / evidence collect).
# Required — those surfaces are DISABLED (503) if neither this nor GF_ADMIN_TOKEN is set.
# The management-api presents it (X-Auditor-Token) on the gateway->C06 hop. openssl rand -hex 32.
GF_AUDITOR_TOKEN=

# The console-identity PUBLIC key (Ed25519 SubjectPublicKeyInfo PEM) the
# management-api pins to VALIDATE C04-signed browser identity tokens. Required in production: the
# gateway REFUSES to start without it (it cannot verify tokens). Fetch it from a running C04 with:
#   curl -s http://identity:8084/v1/keys/console | jq -r .public_key_pem
# C04 signs with the private half at GF_CONSOLE_SIGNING_KEY_PATH (see the identity Deployment); keep
# that key STABLE so tokens verify across restarts. Paste the multi-line PEM as-is.
GF_IDENTITY_CONSOLE_PUBKEY=

# First console login WITHOUT SSO (local bootstrap admin). The Terraform module sets these for you;
# set them HERE only if you install the chart directly. On boot identity creates a platform_admin
# once (idempotent); then log into the console with the email + the PLAINTEXT password you hashed.
# PASSWORD_HASH must be an argon2id HASH (never plaintext) — identity refuses to start otherwise.
# Generate it (no password ever touches the cluster):  python3 scripts/make_admin_hash.py
# Stored raw in the Secret, so no $-escaping is needed here. Optional — omit for OIDC/SSO installs.
GF_BOOTSTRAP_ADMIN_EMAIL=
GF_BOOTSTRAP_ADMIN_PASSWORD_HASH=
# Optional; defaults to the platform tenant 00000000-0000-0000-0000-000000000000.
GF_BOOTSTRAP_ADMIN_TENANT=

